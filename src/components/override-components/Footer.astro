---
import config from "@/config/config.json" assert { type: "json" };
import { markdownify } from "@/lib/utils/textConverter";
import { getTranslations } from "@/lib/utils/languagePerser";

const locale = Astro.currentLocale || "root";
const menu = await getTranslations(locale);
const footer = menu.footer;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h4>{footer.community?.title || "Community"}</h4>
      <ul>
        {footer.community?.links?.map((link: any) => (
          <li><a href={link.url}>{link.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4>{footer.help_links?.title || "Sections"}</h4>
      <ul>
        {footer.help_links?.links?.map((link: any) => (
          <li><a href={link.url}>{link.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4>{footer.company?.title || "Operations"}</h4>
      <ul>
        {footer.company?.links?.map((link: any) => (
          <li><a href={link.url}>{link.name}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container footer-meta">
    <p set:html={markdownify(config?.params?.copyright)} />
  </div>
</footer>

<style>
  @layer starlight.core {
    .site-footer {
      margin-top: 2rem;
      border-top: 1px solid var(--sl-color-hairline);
      background: color-mix(in srgb, var(--sl-color-black) 82%, transparent);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(1, minmax(0, 1fr));
      gap: 1.2rem;
      padding: 2.2rem 0 1.2rem;
    }

    .footer-grid h4 {
      margin: 0;
      font-size: 0.88rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--sl-color-gray-3);
    }

    .footer-grid ul {
      list-style: none;
      margin: 0.8rem 0 0;
      padding: 0;
      display: grid;
      gap: 0.45rem;
    }

    .footer-grid a {
      text-decoration: none;
      color: var(--sl-color-white);
      opacity: 0.92;
    }

    .footer-grid a:hover {
      color: var(--sl-color-accent);
    }

    .footer-meta {
      border-top: 1px solid var(--sl-color-hairline);
      padding: 0.9rem 0 1.5rem;
      color: var(--sl-color-gray-3);
      font-size: 0.88rem;
    }

    @media (min-width: 860px) {
      .footer-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  }
</style>
