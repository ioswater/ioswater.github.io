---
import Search from "./Search.astro";
const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline } = data.hero || {};
const { sidebar } = Astro.locals.starlightRoute;
const locale = Astro.currentLocale || "root";
const blogLink = locale === "en" ? "/en/blog/" : "/blog/";

function getFirstHref(item: any): string | null {
  if (typeof item?.href === "string" && item.href) return item.href;
  if (item?.entries?.length) return getFirstHref(item.entries[0]);
  return null;
}

const quickLinks = sidebar
  .map((item: any) => ({ label: String(item.label).replace(/\[[^\]]+\]\s*/g, ""), href: getFirstHref(item) }))
  .filter((item: any) => item.href)
  .slice(0, 6);
---

<section class="hero-wrap">
  <div class="hero-grid">
    <div class="hero-copy">
      {title && <h1 set:html={title} />}
      {tagline && <p set:html={tagline} class="hero-tagline" />}
      <div class="hero-cta-row">
        <a class="btn btn-primary" href={blogLink}>开始浏览文章</a>
        <a class="btn btn-secondary" href={locale === "en" ? "/en/content/blog-portal/" : "/content/blog-portal/"}>查看导航总览</a>
      </div>
      <div class="hero-search">
        <Search />
      </div>
    </div>

    <div class="hero-panel">
      <h3>快速入口</h3>
      <ul>
        {quickLinks.map((item: any) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  @layer starlight.core {
    .hero-wrap {
      padding: 2rem 0 1.25rem;
    }

    .hero-grid {
      display: grid;
      gap: 1.2rem;
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero-copy h1 {
      font-size: clamp(2.2rem, 5vw, 4.8rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.03em;
      margin: 0;
      max-width: 16ch;
      animation: hero-rise 0.55s ease-out both;
    }

    .hero-tagline {
      margin-top: 1rem;
      font-size: 1.02rem;
      color: var(--sl-color-gray-3);
      max-width: 56ch;
      animation: hero-rise 0.62s ease-out both;
    }

    .hero-cta-row {
      display: flex;
      gap: 0.8rem;
      margin-top: 1rem;
      flex-wrap: wrap;
      animation: hero-rise 0.7s ease-out both;
    }

    .hero-search {
      margin-top: 1rem;
      max-width: 36rem;
      animation: hero-rise 0.78s ease-out both;
    }

    .hero-panel {
      position: relative;
      border: 1px solid var(--sl-color-hairline);
      background: color-mix(in srgb, var(--sl-color-gray-6) 22%, transparent);
      border-radius: 16px;
      padding: 1rem;
      overflow: hidden;
      animation: hero-rise 0.68s ease-out both;
    }

    .hero-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(
          120deg,
          transparent 8%,
          color-mix(in srgb, var(--sl-color-accent) 16%, transparent) 28%,
          transparent 50%
        );
      transform: translateX(-80%);
      transition: transform 0.9s ease;
    }

    .hero-panel:hover::before {
      transform: translateX(80%);
    }

    .hero-panel h3 {
      margin: 0;
      font-size: 0.95rem;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--sl-color-gray-3);
    }

    .hero-panel ul {
      list-style: none;
      margin: 0.8rem 0 0;
      padding: 0;
      display: grid;
      gap: 0.55rem;
    }

    .hero-panel a {
      text-decoration: none;
      color: var(--sl-color-white);
      border-bottom: 1px dashed color-mix(in srgb, var(--sl-color-gray-4) 50%, transparent);
      padding-bottom: 0.2rem;
      transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
      display: inline-flex;
    }

    .hero-panel a:hover {
      color: var(--sl-color-accent);
      border-color: color-mix(in srgb, var(--sl-color-accent) 55%, transparent);
      transform: translateX(2px);
    }

    @keyframes hero-rise {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (min-width: 980px) {
      .hero-grid {
        grid-template-columns: minmax(0, 1fr) minmax(260px, 340px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-copy h1,
      .hero-tagline,
      .hero-cta-row,
      .hero-search,
      .hero-panel {
        animation: none;
      }

      .hero-panel::before,
      .hero-panel a {
        transition: none;
      }
    }
  }
</style>
