---
import { getEntry } from "astro:content";
import Button from "./user-components/Button.astro";
import Section from "./Section.astro";

const locale = Astro.currentLocale || "zh-CN";
const isDefaultLocale = locale === "root" || locale === "zh-CN";

const cta = await getEntry(
  "ctaSection",
  `${isDefaultLocale ? "" : `${locale}/`}call-to-action`
);
const { title, description, enable, fill_button, outline_button } = cta?.data ?? {};
---

{
  enable && (
    <div class="cta-container">
      <Section title={title} description={description}>
        {fill_button?.enable && (
          <Button label={fill_button.label || "开始阅读"} link={fill_button.link || "/blog/"} variant="primary" />
        )}
        {outline_button?.enable && (
          <Button label={outline_button.label || "查看分类"} link={outline_button.link || "/content/blog-portal/"} variant="outline-primary" />
        )}
      </Section>
    </div>
  )
}

<style>
  .cta-container {
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 0.5rem;
  }
</style>
