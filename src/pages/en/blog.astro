---
import { getCollection } from "astro:content";
import BlogHub from "@/components/blog/BlogHub.astro";
import "@/styles/global.css";

const categoryMap: Record<string, string> = {
  "ios-basics": "iOS Fundamentals",
  "ai-project-architecture": "AI Project Architecture",
  "personal-projects": "Personal Projects",
  "profile": "About Me"
};

const docs = await getCollection("docs");

interface HubPost {
  title: string;
  description: string;
  url: string;
  category: string;
  categoryLabel: string;
  date: string;
}

const toDate = (lastUpdated: Date | boolean | undefined): string => {
  if (lastUpdated instanceof Date && !Number.isNaN(lastUpdated.getTime())) {
    return lastUpdated.toISOString().slice(0, 10);
  }

  return "1970-01-01";
};

const posts = docs.reduce<HubPost[]>((acc, entry) => {
  if (entry.id.startsWith("en/")) {
    const seg = entry.id.split("/")[1];
    if (!categoryMap[seg]) return acc;

    acc.push({
      title: entry.data.title,
      description: entry.data.description || "",
      url: `/${entry.id}/`,
      category: seg,
      categoryLabel: categoryMap[seg],
      date: toDate(entry.data.lastUpdated)
    });
  }

  return acc;
}, []);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Hub | LiuLuit Tech Blog</title>
    <meta name="description" content="Filter posts by keyword, category and date." />
  </head>
  <body>
    <BlogHub posts={posts} locale="en" />
  </body>
</html>
